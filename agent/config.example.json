{
  "bind_host": "0.0.0.0",
  "bind_port": 8787,
  "poll_interval_seconds": 30,
  "request_timeout_seconds": 5,
  "slow_threshold_ms": 1500,
  "event_buffer_size": 200,
  "verify_tls": true,
  "auth_token": "",
  "webhook_url": "",

  "latency_anomaly_floor_ms": 800,
  "latency_anomaly_factor": 3.0,
  "auth_failure_burst": 3,
  "server_error_storm": 3,
  "cert_min_days": 14,

  "auto_discover": true,
  "discover_domains": [],
  "discover_via_crtsh": true,
  "discover_paths": ["", "/auth", "/api", "/login", "/admin", "/hr", "/dev", "/files", "/analytics", "/vpn", "/status", "/health"],
  "discover_interval_seconds": 1800,
  "max_discovered_services": 200,

  "services": [
    { "name": "Intranet Root", "url": "https://intranet.kneuralabs.com" },
    { "name": "API Gateway",   "url": "https://intranet.kneuralabs.com/api", "expect_status": 401 }
  ]
}
